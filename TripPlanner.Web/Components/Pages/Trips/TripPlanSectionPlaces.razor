@using TripPlanner.Web.Models

@if (Places == null)
{
    <FluentLabel>Loading places...</FluentLabel>
}
else if (!Places.Any())
{
    <FluentLabel>No places available. Please add some places to your trip.</FluentLabel>
}
else
{
    <FluentCard Style="min-height: 500px;">
        <FluentStack Orientation="Orientation.Horizontal" Style="margin-bottom: 4px;">
            <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">Available Places</FluentLabel>
            <FluentSpacer />
            <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Add())" OnClick="async (e) => await OnAddPlaceClick.InvokeAsync()" Style="padding: 4px 8px; font-size: 0.8em;">
                New
            </FluentButton>
        </FluentStack>
        <FluentLabel Style="font-size: 0.875em; margin-bottom: 8px;">Drag places to days to schedule them</FluentLabel>
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
            @foreach (var place in Places)
            {
                var isScheduled = PlanningTrip!.Days.Any(d => d.Places.Any(p => p.PlaceId == place.Id));
                if (!isScheduled)
                {
                    <FluentCard class="draggable"
                                draggable="true"
                                @ondragstart="@(async (e) => await OnHandleDragStart.InvokeAsync(place.Id))"
                                @ondragend="async (e) => await OnHandleDragEnd.InvokeAsync()"
                                Style="cursor: move; padding: 12px;">
                        <FluentStack Orientation="Orientation.Vertical">
                            <FluentLabel Weight="FontWeight.Bold">@place.Name</FluentLabel>
                            <FluentBadge BackgroundColor="var(--neutral-layer-3)">@place.Category</FluentBadge>
                            <FluentStack Orientation="Orientation.Horizontal">
                                <FluentLabel Style="font-size: 0.875em;">
                                    @place.Latitude.ToString("F2"), @place.Longitude.ToString("F2")
                                </FluentLabel>
                                <FluentSpacer />
                                <FluentButton Appearance="Appearance.Lightweight" IconEnd="@(new Icons.Regular.Size16.Pen())" OnClick="@(async () => await OnEditPlaceClick.InvokeAsync(place))"></FluentButton>
                            </FluentStack>
                        </FluentStack>
                    </FluentCard>
                }
            }
        </FluentStack>
    </FluentCard>
}



@code {
    [Parameter, EditorRequired]
    public IEnumerable<Place>? Places { get; set; }

    [Parameter, EditorRequired]
    public Trip? PlanningTrip { get; set; }
    
    [Parameter, EditorRequired]
    public EventCallback<string> OnHandleDragStart { get; set; }
    
    [Parameter, EditorRequired]
    public EventCallback OnHandleDragEnd { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnAddPlaceClick { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<Place> OnEditPlaceClick { get; set; }
}