@page "/wishlists/{WishlistId}"

@using Microsoft.AspNetCore.Authorization
@using TripPlanner.Web.Components.Shared
@using TripPlanner.Web.Models
@using TripPlanner.Web.Repositories
@using TripPlanner.Web.Services

@attribute [Authorize]

@inject IWishlistRepository WishlistRepository
@inject IPlaceRepository PlaceRepository
@inject IUrlImportJobRepository UrlImportJobRepository
@inject UserService UserService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

@rendermode InteractiveServer

<PageTitle>@(wishlist?.Name ?? "Wishlist")</PageTitle>

@if (wishlist == null)
{
    <FluentProgressRing>Loading wishlist...</FluentProgressRing>
}
else if (!canAccess)
{
    <FluentMessageBar Intent="MessageIntent.Error">
        You do not have permission to view this wishlist.
    </FluentMessageBar>
}
else
{
    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Stretch" Width="100%">
        <FluentToolbar>
            <FluentButton Appearance="Appearance.Lightweight" IconStart="@(new Icons.Regular.Size20.ArrowLeft())" OnClick="@(() => NavigationManager.NavigateTo("/wishlists"))">
                Back to Wishlists
            </FluentButton>
            <FluentSpacer />
            <FluentLabel Typo="Typography.H3">
                <FluentIcon Icon="Icons.Regular.Size24.Heart" Color="Color.Accent" />
                @wishlist.Name
            </FluentLabel>
            <FluentSpacer />
            @if (canEdit)
            {
                <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Add())" OnClick="@ShowAddPlaceDialog">
                    Add Place
                </FluentButton>
            }
        </FluentToolbar>

        @if (!string.IsNullOrEmpty(wishlist.Description))
        {
            <FluentCard>
                <FluentLabel>@wishlist.Description</FluentLabel>
            </FluentCard>
        }

        @if (canEdit)
        {
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                    <FluentLabel Typo="Typography.H5">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Link())" Style="margin-right: 6px;" />
                        Import Places from URLs
                    </FluentLabel>
                    <FluentLabel>
                        Enter one or more URLs (one per line). Each URL will be analysed by AI and a new place will be created for review.
                    </FluentLabel>
                    <FluentTextArea @bind-Value="urlInputText"
                                    Placeholder="https://example.com/place-to-visit"
                                    Rows="4"
                                    Style="width: 100%; font-family: monospace;" />
                    @if (!string.IsNullOrEmpty(urlSubmitError))
                    {
                        <FluentMessageBar Intent="MessageIntent.Error">@urlSubmitError</FluentMessageBar>
                    }
                    <FluentButton Appearance="Appearance.Accent"
                                  IconStart="@(new Icons.Regular.Size20.ArrowUpload())"
                                  OnClick="@SubmitUrls"
                                  Disabled="@(string.IsNullOrWhiteSpace(urlInputText))">
                        Add to Import Queue
                    </FluentButton>
                </FluentStack>
            </FluentCard>
        }

        @if (importJobs != null && importJobs.Count > 0)
        {
            <FluentCard>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 8px;">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
                        <FluentLabel Typo="Typography.H5">
                            <FluentIcon Value="@(new Icons.Regular.Size20.ClipboardTask())" Style="margin-right: 6px;" />
                            Import Queue
                        </FluentLabel>
                        <FluentSpacer />
                        <FluentButton Appearance="Appearance.Lightweight"
                                      IconStart="@(new Icons.Regular.Size20.ArrowClockwise())"
                                      OnClick="@RefreshJobs"
                                      title="Refresh">
                            Refresh
                        </FluentButton>
                    </FluentStack>

                    <FluentDataGrid Items="@importJobs.AsQueryable()" GridTemplateColumns="3fr 1fr 1fr auto" Style="width: 100%;">
                        <PropertyColumn Property="@(j => j.Url)" Title="URL" />
                        <TemplateColumn Title="Status">
                            @{
                                var statusIcon = context.Status switch
                                {
                                    UrlImportJobStatus.Pending => "⏳",
                                    UrlImportJobStatus.Processing => "⚙️",
                                    UrlImportJobStatus.Completed => "✅",
                                    UrlImportJobStatus.Failed => "❌",
                                    _ => "?"
                                };
                            }
                            <span>@statusIcon @context.Status</span>
                        </TemplateColumn>
                        <TemplateColumn Title="Created">
                            <span title="@context.CreatedAt.ToString("o")">@context.CreatedAt.ToLocalTime().ToString("g")</span>
                        </TemplateColumn>
                        <TemplateColumn Title="Actions">
                            @if (context.Status == UrlImportJobStatus.Failed)
                            {
                                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 4px;">
                                    <FluentTooltip Anchor="@($"retry-btn-{context.Id}")" Position="TooltipPosition.Left">
                                        @context.ErrorMessage
                                    </FluentTooltip>
                                    <FluentButton Id="@($"retry-btn-{context.Id}")"
                                                  Appearance="Appearance.Lightweight"
                                                  IconStart="@(new Icons.Regular.Size20.ArrowClockwise())"
                                                  OnClick="@(() => RetryJob(context))"
                                                  title="@context.ErrorMessage">
                                        Retry
                                    </FluentButton>
                                    @if (canEdit)
                                    {
                                        <FluentButton Appearance="Appearance.Lightweight"
                                                      IconStart="@(new Icons.Regular.Size20.Delete())"
                                                      OnClick="@(() => DeleteJob(context.Id))">
                                        </FluentButton>
                                    }
                                </FluentStack>
                            }
                            else if (context.Status == UrlImportJobStatus.Completed && context.CreatedPlaceId != null)
                            {
                                <FluentLabel Color="Color.Success" Style="font-size: 0.85em;">Place created</FluentLabel>
                            }
                        </TemplateColumn>
                    </FluentDataGrid>
                </FluentStack>
            </FluentCard>
        }

        @if (places == null)
        {
            <FluentProgressRing>Loading places...</FluentProgressRing>
        }
        else if (!places.Any())
        {
            <FluentCard>
                <p>This wishlist doesn't have any places yet. Click "Add Place" to start adding places.</p>
            </FluentCard>
        }
        else
        {
            <WishlistPlacesGrid Places="places" CanEdit="@canEdit" OnEditPlace="EditPlace" OnDeletePlace="DeletePlace" OnNotesPlace="OpenNotes" />
        }
    </FluentStack>
}

<FluentDialogProvider />



@code {
    [Parameter]
    public string WishlistId { get; set; } = string.Empty;

    private Wishlist? wishlist;
    private List<Place>? places;
    private List<UrlImportJob>? importJobs;
    private bool canAccess;
    private bool canEdit;
    private string? currentUserId;

    private string urlInputText = string.Empty;
    private string? urlSubmitError;



    protected override async Task OnInitializedAsync()
    {
        currentUserId = await UserService.GetCurrentUserIdAsync();
        if (currentUserId != null)
        {
            await LoadWishlist();
        }
    }

    private async Task LoadWishlist()
    {
        if (currentUserId == null) return;

        wishlist = await WishlistRepository.GetByIdAsync(WishlistId);
        if (wishlist != null)
        {
            canAccess = await WishlistRepository.CanUserAccessAsync(WishlistId, currentUserId);
            if (canAccess)
            {
                canEdit = await WishlistRepository.CanUserEditAsync(WishlistId, currentUserId);
                await LoadPlaces();
                await LoadImportJobs();
            }
        }
    }

    private async Task LoadPlaces()
    {
        places = await PlaceRepository.GetByWishlistIdAsync(WishlistId);
    }

    private async Task LoadImportJobs()
    {
        importJobs = await UrlImportJobRepository.GetByWishlistIdAsync(WishlistId);
    }

    private async Task SubmitUrls()
    {
        urlSubmitError = null;

        if (currentUserId == null || string.IsNullOrWhiteSpace(urlInputText))
            return;

        var lines = urlInputText
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        if (lines.Count == 0)
        {
            urlSubmitError = "Please enter at least one URL.";
            return;
        }

        var invalid = lines.Where(l => !Uri.TryCreate(l, UriKind.Absolute, out _)).ToList();
        if (invalid.Count > 0)
        {
            urlSubmitError = $"Invalid URL(s): {string.Join(", ", invalid)}";
            return;
        }

        foreach (var url in lines)
        {
            var job = new UrlImportJob
            {
                WishlistId = WishlistId,
                Url = url,
                CreatedByUserId = currentUserId,
                Status = UrlImportJobStatus.Pending,
                CreatedAt = DateTime.UtcNow
            };
            await UrlImportJobRepository.AddAsync(job);
        }

        urlInputText = string.Empty;
        await LoadImportJobs();
    }

    private async Task RefreshJobs()
    {
        await LoadImportJobs();
        await LoadPlaces();
    }

    private async Task RetryJob(UrlImportJob job)
    {
        job.Status = UrlImportJobStatus.Pending;
        job.ErrorMessage = null;
        job.ProcessedAt = null;
        await UrlImportJobRepository.UpdateAsync(job);
        await LoadImportJobs();
    }

    private async Task DeleteJob(string jobId)
    {
        await UrlImportJobRepository.DeleteAsync(jobId);
        await LoadImportJobs();
    }

    private async Task ShowAddPlaceDialog()
    {
        var dialog = await DialogService.ShowDialogAsync<PlaceDialog>(new Place() { WishlistId = WishlistId }, new DialogParameters()
        {
            PreventDismissOnOverlayClick = true,
            PreventScroll = true,
            TrapFocus = true
        });

        var result = await dialog.Result;

        if (!result.Cancelled && result.Data is not null)
        {
            
            await LoadPlaces();
            StateHasChanged();
        }
    }

    private async Task EditPlace(Place place)
    {
        var dialog = await DialogService.ShowDialogAsync<PlaceDialog>(place, new DialogParameters()
        {
            Title = "Edit Place",
            PreventDismissOnOverlayClick = true,
            PreventScroll = true,
            TrapFocus = true
        });

        var result = await dialog.Result;

        if (!result.Cancelled && result.Data is not null)
        {
            StateHasChanged();
        }
    }

    private async Task OpenNotes(Place place)
    {
        var panel = await DialogService.ShowPanelAsync<PlaceNotesDrawer>(place, new DialogParameters()
        {
            Title = $"Notes: {place.Name}",
            Width = "min(95vw, 1000px)",
            PreventDismissOnOverlayClick = false,
        });

        await panel.Result;
    }

    private async Task DeletePlace(string placeId)
    {
        var place = places?.FirstOrDefault(p => p.Id == placeId);
        var name = place?.Name ?? "this place";
        var dialog = await DialogService.ShowDialogAsync<ConfirmDialog>(
            new ConfirmDialogContent($"Are you sure you want to delete \"{name}\"?"),
            new DialogParameters { Title = "Confirm Delete", PreventDismissOnOverlayClick = true });
        var result = await dialog.Result;
        if (result.Cancelled) return;

        await PlaceRepository.DeleteAsync(placeId);
        await LoadPlaces();
    }
}
